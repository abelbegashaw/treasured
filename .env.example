# Copy this file to `.env` and fill in the values.

# Supabase — Project Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloudinary — create a free account, then Settings > Upload > add an UNSIGNED upload preset.
# VITE_CLOUDINARY_CLOUD_NAME is shown on your Cloudinary dashboard.
# For video: set the preset's Resource type to "Auto" and add an incoming
# transformation (e.g. c_limit,w_1920,q_auto) to cap stored size. See supabase/README.md.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Auth passcode — DO NOT put the passcode here.
# Anything prefixed VITE_ is bundled into the public browser build. The shared
# passcode and the hidden account credentials are SERVER secrets set on the
# verify-passcode Edge Function (APP_PASSCODE / SHARED_EMAIL / SHARED_PASSWORD).
# See supabase/README.md.
